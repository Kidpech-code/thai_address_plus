							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "districts", ":pcode"],
							"variable": [{ "key": "pcode", "value": "TH1001", "description": "รหัสอำเภอ เช่น TH1001 = พระนคร" }]
						}
					}
				},
				{
					"name": "List Sub-districts in District",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/districts/:pcode/sub-districts",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "districts", ":pcode", "sub-districts"],
							"variable": [{ "key": "pcode", "value": "TH1001" }],
							"query": [
								{ "key": "with_geom", "value": "true", "disabled": true },
								{ "key": "simplified", "value": "true", "disabled": true }
							]
						}
					}
				},
				{
					"name": "Get District Neighbors",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/districts/:pcode/neighbors",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "districts", ":pcode", "neighbors"],
							"variable": [{ "key": "pcode", "value": "TH1001" }]
						}
					}
				},
				{
					"name": "Get District GeoJSON",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/geo+json" }],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/districts/:pcode/geojson",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "districts", ":pcode", "geojson"],
							"variable": [{ "key": "pcode", "value": "TH1001" }]
						}
					}
				}
			]
		},
		{
			"name": "3. Sub-districts (ตำบล)",
			"item": [
				{
					"name": "Filter Sub-districts (Faceted)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/sub-districts",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "sub-districts"],
							"query": [
								{ "key": "province", "value": "TH10", "description": "กรองตามจังหวัด", "disabled": true },
								{ "key": "district", "value": "TH1001", "description": "กรองตามอำเภอ", "disabled": true },
								{ "key": "is_coastal", "value": "true", "description": "เฉพาะชายทะเล", "disabled": true },
								{ "key": "is_island", "value": "true", "description": "เฉพาะเกาะ", "disabled": true },
								{ "key": "max_distance_bkk_km", "value": "50", "description": "รัศมีจากกรุงเทพฯ (km)", "disabled": true },
								{ "key": "limit", "value": "50", "disabled": true },
								{ "key": "offset", "value": "0", "disabled": true }
							]
						}
					}
				},
				{
					"name": "Get Sub-district by pcode",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/sub-districts/:pcode",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "sub-districts", ":pcode"],
							"variable": [{ "key": "pcode", "value": "TH100101", "description": "รหัสตำบล" }]
						}
					}
				},
				{
					"name": "Get Sub-district Neighbors",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/sub-districts/:pcode/neighbors",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "sub-districts", ":pcode", "neighbors"],
							"variable": [{ "key": "pcode", "value": "TH100101" }]
						}
					}
				},
				{
					"name": "Get Sub-district GeoJSON",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/geo+json" }],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/sub-districts/:pcode/geojson?simplified=true",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "sub-districts", ":pcode", "geojson"],
							"variable": [{ "key": "pcode", "value": "TH100101" }],
							"query": [{ "key": "simplified", "value": "true" }]
						}
					}
				},
				{
					"name": "List Villages in Sub-district",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/sub-districts/:pcode/villages",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "sub-districts", ":pcode", "villages"],
							"variable": [{ "key": "pcode", "value": "TH100101" }]
						}
					}
				}
			]
		},
		{
			"name": "4. Other Lookups (zip / region)",
			"item": [
