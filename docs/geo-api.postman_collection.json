{
	"info": {
		"name": "Thailand Geo API — Complete",
		"description": "Thailand Geographic API ครบทุก endpoint (35 routes)\nBase: https://api.kidpech.app/api/v1/geo\nAuth: ไม่ต้องการ (public, read-only)\nRate limit: 60 req/min/IP (ยกเว้น POST /reverse/batch = 10 req/min)\n\nResponse envelope:\n{ status, message, data }\nยกเว้น GeoJSON/MVT endpoints ที่ส่ง raw spec object โดยตรง",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Provinces (จังหวัด)",
			"item": [
				{
					"name": "List Provinces",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/provinces",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "provinces"],
							"query": [
								{ "key": "region", "value": "north", "description": "north | northeast | central | east | west | south", "disabled": true },
								{ "key": "is_coastal", "value": "true", "description": "เฉพาะจังหวัดชายทะเล", "disabled": true },
								{ "key": "with_geom", "value": "true", "description": "ส่ง GeoJSON FeatureCollection", "disabled": true },
								{ "key": "simplified", "value": "true", "description": "ใช้ simplified geometry (default: true)", "disabled": true }
							]
						}
					}
				},
				{
					"name": "Get Province by pcode",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/provinces/:pcode",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "provinces", ":pcode"],
							"variable": [{ "key": "pcode", "value": "TH10", "description": "รหัสจังหวัด เช่น TH10 = กรุงเทพฯ" }]
						}
					}
				},
				{
					"name": "List Districts in Province",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/provinces/:pcode/districts",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "provinces", ":pcode", "districts"],
							"variable": [{ "key": "pcode", "value": "TH10" }],
							"query": [
								{ "key": "with_geom", "value": "true", "description": "ส่ง GeoJSON FeatureCollection", "disabled": true },
								{ "key": "simplified", "value": "true", "disabled": true }
							]
						}
					}
				},
				{
					"name": "Get Province Neighbors",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/provinces/:pcode/neighbors?depth=1",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "provinces", ":pcode", "neighbors"],
							"variable": [{ "key": "pcode", "value": "TH10" }],
							"query": [{ "key": "depth", "value": "1", "description": "ระดับความลึก 1–3" }]
						}
					}
				},
				{
					"name": "Get Province GeoJSON",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/geo+json" }],
						"url": {
							"raw": "{{base_url}}/api/v1/geo/provinces/:pcode/geojson?simplified=true",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "geo", "provinces", ":pcode", "geojson"],
							"variable": [{ "key": "pcode", "value": "TH10" }],
							"query": [{ "key": "simplified", "value": "true" }]
						}
					}
				}
			]
		},
		{
			"name": "2. Districts (อำเภอ)",
			"item": [
